require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

require 'json'
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

def ccache_enabled?(podfile_properties)
 return ENV['USE_CCACHE'] == '1' if ENV['USE_CCACHE']
 podfile_properties['apple.ccacheEnabled'] == 'true'
end

ENV['RCT_NEW_ARCH_ENABLED'] ||= '0' if podfile_properties['newArchEnabled'] == 'false'
ENV['EX_DEV_CLIENT_NETWORK_INSPECTOR'] ||= podfile_properties['EX_DEV_CLIENT_NETWORK_INSPECTOR']
# Force build from source to avoid Maven tarball download crashes
ENV['RCT_USE_RN_DEP'] = '0'
ENV['RCT_USE_PREBUILT_RNCORE'] = '0'

project 'ecpower.xcodeproj'

platform :ios, '16.6'

prepare_react_native_project!

target 'ecpower' do
 use_expo_modules!

 if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
   config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"]
 else
   config_command = [
     'npx',
     'expo-modules-autolinking',
     'react-native-config',
     '--json',
     '--platform',
     'ios'
   ]
 end

 config = use_native_modules!(config_command)

 use_frameworks! :linkage => podfile_properties['ios.useFrameworks'].to_sym if podfile_properties['ios.useFrameworks']
 use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

 use_react_native!(
   :path => config[:reactNativePath],
   :hermes_enabled => podfile_properties['expo.jsEngine'] == nil || podfile_properties['expo.jsEngine'] == 'hermes',
   :app_path => "#{Pod::Config.instance.installation_root}/..",
   :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
 )

 post_install do |installer|
   react_native_post_install(
     installer,
     config[:reactNativePath],
     :mac_catalyst_enabled => false,
     :ccache_enabled => ccache_enabled?(podfile_properties),
   )

   # Fix Hermes script phase: set it to run based on dependency analysis
   # This prevents it running every build and avoids build system crashes
   installer.pods_project.targets.each do |target|
     if target.name == 'hermes-engine'
       target.build_phases.each do |phase|
         if phase.respond_to?(:name) && phase.name&.include?('[CP-User] [Hermes] Replace Hermes')
           phase.always_out_of_date = '0'
         end
       end
     end
   end

   installer.pods_project.targets.each do |target|
     target.build_configurations.each do |config|
       # Set deployment target for all pods
       config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.4'
      
       # Swift version
       config.build_settings['SWIFT_VERSION'] = '5.0'
      
       # Disable bitcode
       config.build_settings['ENABLE_BITCODE'] = 'NO'

       # Disable index store to prevent build system crashes
       config.build_settings['COMPILER_INDEX_STORE_ENABLE'] = 'NO'
       config.build_settings['INDEX_ENABLE_DATA_STORE'] = 'NO'
       
       # === GLOBAL SWIFT FIXES FOR ALL TARGETS ===
       
       # Optimization levels
       if config.name == 'Debug'
         config.build_settings['SWIFT_OPTIMIZATION_LEVEL'] = '-Onone'
       else
         config.build_settings['SWIFT_OPTIMIZATION_LEVEL'] = '-O'
       end
       
       # Use singlefile compilation to avoid incremental build issues
       config.build_settings['SWIFT_COMPILATION_MODE'] = 'singlefile'
       
       # Suppress all warnings to prevent warning-as-error issues
       config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
       config.build_settings['CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER'] = 'NO'
       
       # Swift flags to suppress errors
       config.build_settings['OTHER_SWIFT_FLAGS'] ||= ['$(inherited)']
       config.build_settings['OTHER_SWIFT_FLAGS'] << '-suppress-warnings'
       config.build_settings['OTHER_SWIFT_FLAGS'] << '-Xfrontend'
       config.build_settings['OTHER_SWIFT_FLAGS'] << '-no-verify-emitted-module-interface'
       
       # Disable strict concurrency checking
       config.build_settings['SWIFT_STRICT_CONCURRENCY'] = 'minimal'
       
       # Disable library evolution (can cause Swift issues)
       config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'NO'
       config.build_settings['SWIFT_EMIT_MODULE_INTERFACE'] = 'NO'
       
       # Enable modules
       config.build_settings['CLANG_ENABLE_MODULES'] = 'YES'
       
       # === SPECIFIC FIXES FOR NITRO/IAP MODULES ===
       if target.name.include?('Nitro') || target.name == 'NitroIap'
         # C++20 for NitroModules
         config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++20'
         config.build_settings['CLANG_CXX_LIBRARY'] = 'libc++'
         
         # Preprocessor definitions
         config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
         config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'FOLLY_NO_CONFIG=1'
         
         # Header search paths
         config.build_settings['HEADER_SEARCH_PATHS'] ||= ['$(inherited)']
         config.build_settings['HEADER_SEARCH_PATHS'] << '"${PODS_ROOT}/Headers/Public"'
         config.build_settings['HEADER_SEARCH_PATHS'] << '"${PODS_ROOT}/Headers/Public/React-Core"'
         config.build_settings['HEADER_SEARCH_PATHS'] << '"${PODS_ROOT}/Headers/Public/React-Codegen"'
         config.build_settings['HEADER_SEARCH_PATHS'] << '"${PODS_ROOT}/Headers/Public/ReactCommon"'
         config.build_settings['HEADER_SEARCH_PATHS'] << '"${PODS_CONFIGURATION_BUILD_DIR}/React-Codegen/React_Codegen.framework/Headers"'
         
         # C++ interoperability
         config.build_settings['CLANG_ENABLE_OBJC_INTEROP'] = 'YES'
         config.build_settings['OTHER_SWIFT_FLAGS'] << '-cxx-interoperability-mode=default'
       end
       
       # === FIXES FOR EXPO MODULES ===
       if target.name.include?('Expo') || target.name.include?('EX')
         # Ensure proper module setup
         config.build_settings['DEFINES_MODULE'] = 'YES'
         config.build_settings['CLANG_ENABLE_MODULES'] = 'YES'
       end
       
       # === FIX FOR clang Illegal instruction crashes on x86_64 simulator ===
       # Affects ReactCodegen (ShadowNodes.cpp), RNReanimated, RNScreens, etc.
       clang_crash_targets = ['ReactCodegen', 'RNReanimated', 'RNScreens', 'RNWorklets', 'react-native-pdf', 'RNGestureHandler', 'RNSVG', 'RNDateTimePicker', 'RNCAsyncStorage', 'RNCPicker', 'react-native-safe-area-context', 'react-native-webview', 'react-native-blob-util', 'RNFS']
       if clang_crash_targets.include?(target.name)
         config.build_settings['GCC_OPTIMIZATION_LEVEL'] = '0'
         config.build_settings['LLVM_LTO'] = 'NO'
         config.build_settings['OTHER_CFLAGS'] ||= ['$(inherited)']
         config.build_settings['OTHER_CFLAGS'] << '-O0'
         config.build_settings['OTHER_CFLAGS'] << '-fno-inline-functions'
         config.build_settings['OTHER_CPLUSPLUSFLAGS'] ||= ['$(inherited)']
         config.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-O0'
         config.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-fno-inline-functions'
       end

       # === FIX FOR RNReanimated folly/coro/Coroutine.h missing header ===
       if target.name == 'RNReanimated'
         config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
         config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'FOLLY_CFG_NO_COROUTINES=1'
         config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'FOLLY_NO_CONFIG=1'
         config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'FOLLY_MOBILE=1'
         config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'FOLLY_USE_LIBCPP=1'
       end

       # === FIX FOR RNScreens clang segfault (RNSViewControllerInvalidator.mm) ===
       if target.name == 'RNScreens'
         config.build_settings['GCC_OPTIMIZATION_LEVEL'] = '0'
         config.build_settings['LLVM_LTO'] = 'NO'
         config.build_settings['OTHER_CFLAGS'] ||= ['$(inherited)']
         config.build_settings['OTHER_CFLAGS'] << '-O0'
         config.build_settings['OTHER_CFLAGS'] << '-fno-objc-arc-exceptions'
         config.build_settings['OTHER_CFLAGS'] << '-fno-inline-functions'
         config.build_settings['OTHER_CFLAGS'] << '-fno-optimize-sibling-calls'
         config.build_settings['OTHER_CPLUSPLUSFLAGS'] ||= ['$(inherited)']
         config.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-O0'
         config.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-fno-inline-functions'
       end
     end
   end
   
   # === FIX PROJECT-LEVEL SETTINGS ===
   installer.pods_project.build_configurations.each do |config|
     config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
   end
 end
end